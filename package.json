{
  "name": "karta",
  "version": "0.1.0",
  "description": "MCP server that gives Claude Code stack-aware codebase exploration tools for NestJS, Next.js, and plain TypeScript projects.",
  "type": "module",
  "bin": {
    "karta": "./dist/index.js",
    "karta-viewer": "./dist/viewer/cli.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "viewer": "node dist/viewer/cli.js",
    "dev": "tsc -w",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "claude",
    "claude-code",
    "codebase",
    "architecture",
    "nestjs",
    "nextjs",
    "typescript",
    "model-context-protocol"
  ],
  "author": "Zekarias Tesfaye",
  "license": "MIT",
  "homepage": "https://github.com/zekariasT/karta#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zekariasT/karta.git"
  },
  "bugs": {
    "url": "https://github.com/zekariasT/karta/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "ts-morph": "^24.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^4.1.7",
    "typescript": "^5.5.4",
    "vitest": "^4.1.7"
  }
}
